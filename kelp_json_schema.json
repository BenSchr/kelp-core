          "title": "Schema"
        },
        "name": {
          "description": "Table name",
          "title": "Name",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Human-readable description of the table",
          "title": "Description"
        },
        "spark_conf": {
          "additionalProperties": true,
          "description": "Spark configuration properties",
          "title": "Spark Conf",
          "type": "object"
