            "type": "string"
          },
          "title": "Managed Column Tags",
          "type": "array"
        },
        "table_property_mode": {
          "default": "append",
          "description": "How to apply table properties to remote catalog",
          "enum": [
            "append",
            "managed"
          ],
          "title": "Table Property Mode",
          "type": "string"
        },
        "managed_table_properties": {
          "description": "List of property keys to manage on tables",
          "items": {
            "type": "string"
          },
          "title": "Managed Table Properties",
          "type": "array"
        }
      },
      "title": "RemoteCatalogConfig",
      "type": "object"
    },
    "SDPQuality": {
      "description": "Spark Data Pruning (SDP) quality configuration.\n\nAttributes:\n    engine: Quality engine type (always \"sdp\").\n    level: Level at which quality is enforced (always \"row\" for SDP).\n    expect_all: Dictionary of SQL expressions that must pass.\n    expect_all_or_drop: Dictionary of SQL expressions; rows failing drop.\n    expect_all_or_fail: Dictionary of SQL expressions; job fails if any fail.\n    expect_all_or_quarantine: Dictionary of SQL expressions; failures quarantine rows.",
      "properties": {
        "engine": {
          "const": "sdp",
          "description": "Quality engine type",
          "title": "Engine",
          "type": "string"
        },
        "level": {
          "const": "row",
          "default": "row",
          "description": "Quality enforcement level",
          "title": "Level",
          "type": "string"
        },
        "expect_all": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "SQL expressions that must pass",
          "title": "Expect All",
          "type": "object"
        },
        "expect_all_or_drop": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "SQL expressions; failing rows are dropped",
          "title": "Expect All Or Drop",
          "type": "object"
        },
        "expect_all_or_fail": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "SQL expressions; job fails if any expression fails",
          "title": "Expect All Or Fail",
          "type": "object"
        },
        "expect_all_or_quarantine": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "SQL expressions; failing rows are quarantined",
          "title": "Expect All Or Quarantine",
          "type": "object"
        }
      },
      "required": [
        "engine"
      ],
      "title": "SDPQuality",
      "type": "object"
    },
    "Table": {
      "description": "Table definition in Unity Catalog.\n\nRepresents a table in Databricks Unity Catalog with all its configuration,\nincluding schema, properties, quality checks, and constraints.\n\nAttributes:\n    origin_file_path: Path to the source YAML file defining this table.\n    table_type: Type of table (managed, external, view, streaming_table, etc.).\n    catalog: Unity Catalog name where the table resides.\n    schema_: Schema/database name where the table resides.\n    name: Table name.\n    description: Human-readable description of the table.\n    spark_conf: Spark configuration properties for the table.\n    table_properties: Databricks table properties.\n    path: Physical path for external tables or custom locations.\n    partition_cols: List of column names to use for partitioning.\n    cluster_by_auto: Enable automatic clustering optimization.\n    cluster_by: List of column names to use for explicit clustering (max 4).\n    row_filter: SQL expression to filter rows based on security policies.\n    columns: List of column definitions for the table.\n    quality: Data quality configuration (SDPQuality or DQXQuality).\n    constraints: List of constraints (primary key, foreign key).\n    tags: Metadata tags for the table.\n    raw_config: Original unparsed configuration (preserves placeholder variables).",
      "properties": {
        "table_type": {
          "$ref": "#/$defs/TableType",
          "default": "managed",
          "description": "Type of table: managed, external, view, streaming_table, etc."
